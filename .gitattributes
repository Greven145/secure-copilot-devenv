# Normalize line endings to LF on checkout
* text=auto eol=lf

# Force LF for shell scripts
*.sh text eol=lf

# Force LF for source/config files
*.cs text eol=lf
*.csproj text eol=lf
*.slnx text eol=lf
*.props text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.md text eol=lf
*.gitignore text eol=lf
Dockerfile text eol=lf
