# .gitignore for .NET + Node.js + Terraform projects

# .NET
bin/
obj/
dist/
*.dll
*.exe
*.pdb
*.so
*.dylib
.vs/
.vscode/
.idea/
*.user
*.suo
*.userosscache
*.sln.docstates
.coverage
coverage/
opencover/
reportgenerator/
TestResults/
*.trx

# npm / Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
dist/
build/

# Environment
.env
.env.local
.env.*.local
secrets.json
appsettings.*.json

# OS
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# IDE
.vscode/settings.json
.vscode/launch.json
.vscode/tasks.json
.idea/
*.iml

# Terraform
.terraform/
.terraform.lock.hcl
*.tfstate
*.tfstate.backup
.tfvars
.tfvars.json

# Pre-commit / Git
.pre-commit/.git/

__pycache__/

# Build artifacts
dist/
build/
.marp/
presentation.html
presentation.pdf

# Logs
logs/
*.log

# Temporary files
*.tmp
*.temp
tmp/
temp/

# .nuget
.nuget/

# dotnet runfile-discovery cache (local tooling state, not project config)
dotnet/runfile-discovery/
